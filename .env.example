# --- Telegram ---------------------------------------------------------------
TELEGRAM_BOT_TOKEN=

# --- AI provider ------------------------------------------------------------
# Which LLM powers receipt recognition and item classification: gemini | claude
AI_PROVIDER=gemini

# --- Google Gemini (AI Studio) — used when AI_PROVIDER=gemini ----------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Anthropic — used when AI_PROVIDER=claude -------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- PostgreSQL -------------------------------------------------------------
# Used by the postgres service in docker-compose.
POSTGRES_USER=family
POSTGRES_PASSWORD=family
POSTGRES_DB=family_finance

# Used by the bot to connect (note: host is "postgres" inside docker).
DATABASE_URL=postgresql+asyncpg://family:family@postgres:5432/family_finance
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# --- NBK Exchange Rates -----------------------------------------------------
NBK_API_URL=https://nationalbank.kz/rss/get_rates.cfm

# --- NCT National Catalog ---------------------------------------------------
NCT_API_BASE_URL=https://nationalcatalog.kz/gwp
NCT_API_KEY=
NCT_CACHE_TTL=86400

# --- App --------------------------------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=development
